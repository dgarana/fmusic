# --- Dependencies & build outputs ------------------------------------
node_modules/
out/
dist/
.vite/
.turbo/

# --- Bundled runtime binaries (fetched by scripts/postinstall.js) ----
# yt-dlp and ffmpeg are downloaded per-platform at install time; do not
# check them into the repo. Ignore the _contents_ of resources/bin/ but
# keep the directory present via a .gitkeep placeholder.
resources/bin/*
!resources/bin/.gitkeep

# --- Runtime / user data (database backups, downloaded media) --------
# The library SQLite DB lives under the OS userData folder and must
# never be tracked; keep this rule in case someone runs the app with a
# relative DB path during debugging.
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
/backups/

# --- Electron / electron-builder caches ------------------------------
.electron/
.cache/

# --- TypeScript ------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# --- Environment & secrets -------------------------------------------
.env
.env.*
!.env.example

# --- Editors & OS cruft ----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# --- Logs ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Test / coverage -------------------------------------------------
coverage/
*.lcov
.nyc_output/

# --- Temporary / scratch --------------------------------------------
*.tmp
*.temp
tmp/
scratch/
.claude/
