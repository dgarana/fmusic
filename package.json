{
  "name": "fmusic",
  "version": "0.8.0",
  "description": "Desktop app to download music from YouTube, manage a local library and play it back with FMusic.",
  "main": "out/main/index.js",
  "author": "dgara",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js && electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "screenshots:readme": "npm run build && node scripts/generate-readme-screenshots.js",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@svrooij/sonos": "^2.5.0",
    "better-sqlite3": "^12.9.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "howler": "^2.2.4",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.6",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
